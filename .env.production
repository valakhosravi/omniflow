# Production Environment Variables
# This file is for production environment

# Main API Base URL - Replace with your production API URL
NEXT_PUBLIC_API_BASE_URL=http://app-gateway:8080

# Camunda API Base URL - Replace with your production Camunda API URL
NEXT_PUBLIC_CAMUNDA_API_BASE_URL=http://bpms-gateway:8080

# Environment
NODE_ENV=production
NEXT_PUBLIC_NODE_ENV=production
NEXT_PUBLIC_APP_ENV=production